# ───────── Roznama environment ─────────
# Copy to `.env` for local dev. On Vercel set these in Project → Settings → Env Vars.

# Supabase project (Project Settings → API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Optional, server-side only — used for admin/maintenance scripts, never exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=

# API server
PORT=8787
# Comma-separated allowed origins, or * for any (dev).
CORS_ORIGIN=*

# ───────── Frontend (Vite) — prefix MUST be VITE_ ─────────
# These are safe to expose (anon key is public by design + protected by RLS).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Where the web app calls the API. Same-origin "/api" works on Vercel.
VITE_API_BASE=/api
